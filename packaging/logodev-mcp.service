[Unit]
Description=Logo.dev MCP Server
Documentation=https://pvliesdonk.github.io/logodev-mcp/
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=logodev-mcp
Group=logodev-mcp

# Configuration via environment file
EnvironmentFile=-/etc/logodev-mcp/env

# Start the server in HTTP mode
ExecStart=/opt/logodev-mcp/venv/bin/logodev-mcp serve --transport http

# State directory (auto-creates /var/lib/logodev-mcp/)
StateDirectory=logodev-mcp

# Restart policy
Restart=on-failure
RestartSec=5

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=logodev-mcp

# --- Security hardening ---

# Filesystem
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/lib/logodev-mcp
# Add extra ReadWritePaths if your data directory is elsewhere:
#ReadWritePaths=/home/user/data

# Capabilities
NoNewPrivileges=yes
CapabilityBoundingSet=
AmbientCapabilities=

# Kernel
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes

# Devices
PrivateDevices=yes
DevicePolicy=closed

# Network — only IPv4/IPv6 + Unix sockets (no Netlink, etc.)
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

# System calls
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

# Misc
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictNamespaces=yes

# Python/numpy requires writable+executable memory for JIT
MemoryDenyWriteExecute=no

# Process
# 0027 allows group-read so admins in the logodev-mcp group can
# inspect data/index files directly. Owner retains full access.
UMask=0027

[Install]
WantedBy=multi-user.target
