{
  "version": 1,
  "meta": {
    "projectName": "logodev-mcp",
    "dockerImage": "ghcr.io/pvliesdonk/logodev-mcp:latest",
    "envPrefix": "LOGODEV_MCP"
  },
  "secretKeys": [
    "LOGODEV_MCP_PUBLISHABLE_KEY",
    "LOGODEV_MCP_SECRET_KEY",
    "LOGODEV_MCP_BEARER_TOKEN",
    "LOGODEV_MCP_OIDC_CLIENT_SECRET",
    "LOGODEV_MCP_OIDC_JWT_SIGNING_KEY"
  ],
  "questions": [
    {
      "id": "deployment",
      "label": "Where will the server run?",
      "help": "Local stdio for Claude Desktop/Code, or an HTTP server for Docker/systemd.",
      "type": "select",
      "options": [
        { "value": "local", "label": "Local (Claude Desktop / Claude Code, stdio)", "emit": { "LOGODEV_MCP_TRANSPORT": "stdio" } },
        { "value": "server", "label": "Server (HTTP — Docker / Compose / systemd)", "emit": { "LOGODEV_MCP_TRANSPORT": "http" } }
      ]
    },
    {
      "id": "publishable_key",
      "label": "logo.dev publishable key",
      "help": "pk_... key from the logo.dev dashboard. Enables the get_logo tool. Leave blank to hide it.",
      "type": "text",
      "var": "LOGODEV_MCP_PUBLISHABLE_KEY"
    },
    {
      "id": "secret_key",
      "label": "logo.dev secret key",
      "help": "sk_... key from the logo.dev dashboard. Enables search_brands, describe_company, and get_brand (subject to your plan). Leave blank to hide them.",
      "type": "text",
      "var": "LOGODEV_MCP_SECRET_KEY"
    },
    {
      "id": "detect_plan",
      "label": "Detect plan and hide unentitled tools",
      "help": "On by default: probe describe/brand at startup and hide the tools your logo.dev plan does not allow. Turn off to always register every secret-key tool.",
      "type": "bool",
      "var": "LOGODEV_MCP_DETECT_PLAN",
      "advancedGroup": "Plan detection"
    },
    {
      "id": "state_dir",
      "label": "State directory",
      "help": "Holds the cached plan-detection verdict (entitlements.json). On Docker this is fixed to the state volume.",
      "type": "text",
      "var": "LOGODEV_MCP_STATE_DIR",
      "advancedGroup": "Plan detection",
      "dockerPath": "/data/state"
    },
    {
      "id": "base_url",
      "label": "Public base URL",
      "help": "e.g. https://mcp.example.com — required for OIDC and MCP Apps.",
      "type": "text",
      "var": "LOGODEV_MCP_BASE_URL",
      "showIf": { "deployment": ["server"] }
    },
    {
      "id": "http_path",
      "label": "HTTP endpoint path",
      "help": "Mount path for the MCP endpoint, e.g. /mcp. Defaults to /mcp when unset.",
      "type": "text",
      "var": "LOGODEV_MCP_HTTP_PATH",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "Server"
    },
    {
      "id": "host",
      "label": "Bind host",
      "help": "Interface the HTTP server binds to. Default 127.0.0.1.",
      "type": "text",
      "var": "LOGODEV_MCP_HOST",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "Server"
    },
    {
      "id": "port",
      "label": "Port",
      "help": "TCP port for the HTTP server. Default 8000.",
      "type": "text",
      "var": "LOGODEV_MCP_PORT",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "Server"
    },
    {
      "id": "auth",
      "label": "Authentication",
      "type": "select",
      "showIf": { "deployment": ["server"] },
      "options": [
        { "value": "none", "label": "None" },
        { "value": "bearer", "label": "Bearer token" },
        { "value": "oidc", "label": "OIDC" },
        { "value": "both", "label": "Bearer + OIDC" }
      ]
    },
    {
      "id": "bearer_token",
      "label": "Bearer token",
      "help": "Any non-empty string enables bearer auth. Browser-only.",
      "type": "text",
      "var": "LOGODEV_MCP_BEARER_TOKEN",
      "showIf": { "deployment": ["server"], "auth": ["bearer", "both"] }
    },
    {
      "id": "oidc_config_url",
      "label": "OIDC discovery URL",
      "help": "e.g. https://auth.example.com/.well-known/openid-configuration",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_CONFIG_URL",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] }
    },
    {
      "id": "oidc_client_id",
      "label": "OIDC client ID",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_CLIENT_ID",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] }
    },
    {
      "id": "oidc_client_secret",
      "label": "OIDC client secret",
      "help": "Browser-only; never in the shareable link.",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_CLIENT_SECRET",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] }
    },
    {
      "id": "oidc_jwt_signing_key",
      "label": "OIDC JWT signing key",
      "help": "Required on Linux/Docker — the default is ephemeral and invalidates tokens on restart. Generate: openssl rand -hex 32.",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_JWT_SIGNING_KEY",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] }
    },
    {
      "id": "oidc_audience",
      "label": "OIDC audience",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_AUDIENCE",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] },
      "advancedGroup": "Auth"
    },
    {
      "id": "oidc_required_scopes",
      "label": "OIDC required scopes (CSV)",
      "type": "text",
      "var": "LOGODEV_MCP_OIDC_REQUIRED_SCOPES",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] },
      "advancedGroup": "Auth"
    },
    {
      "id": "oidc_verify_access_token",
      "label": "Verify access token (not id token)",
      "type": "bool",
      "var": "LOGODEV_MCP_OIDC_VERIFY_ACCESS_TOKEN",
      "showIf": { "deployment": ["server"], "auth": ["oidc", "both"] },
      "advancedGroup": "Auth"
    },
    {
      "id": "bearer_tokens_file",
      "label": "Bearer tokens file (TOML)",
      "help": "Path to a TOML file of per-token subjects; overrides the single BEARER_TOKEN.",
      "type": "text",
      "var": "LOGODEV_MCP_BEARER_TOKENS_FILE",
      "showIf": { "deployment": ["server"], "auth": ["bearer", "both"] },
      "advancedGroup": "Auth"
    },
    {
      "id": "bearer_default_subject",
      "label": "Bearer default subject",
      "help": "Subject assigned to the single bearer token. Default bearer-anon.",
      "type": "text",
      "var": "LOGODEV_MCP_BEARER_DEFAULT_SUBJECT",
      "showIf": { "deployment": ["server"], "auth": ["bearer", "both"] },
      "advancedGroup": "Auth"
    },
    {
      "id": "kv_store_url",
      "label": "KV store URL (HTTP session persistence)",
      "type": "text",
      "var": "LOGODEV_MCP_KV_STORE_URL",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "Persistence"
    },
    {
      "id": "event_store_url",
      "label": "Event store URL (HTTP resumability)",
      "help": "Alternative event-store URL for HTTP resumability; prefer KV_STORE_URL for new deployments.",
      "type": "text",
      "var": "LOGODEV_MCP_EVENT_STORE_URL",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "Persistence"
    },
    {
      "id": "app_domain",
      "label": "MCP Apps domain",
      "help": "Public domain that serves MCP Apps UI resources.",
      "type": "text",
      "var": "LOGODEV_MCP_APP_DOMAIN",
      "showIf": { "deployment": ["server"] },
      "advancedGroup": "MCP Apps"
    },
    {
      "id": "log_level",
      "label": "Log level",
      "type": "text",
      "var": "FASTMCP_LOG_LEVEL",
      "advancedGroup": "Logging"
    },
    {
      "id": "rich_logging",
      "label": "Rich logging",
      "type": "bool",
      "var": "FASTMCP_ENABLE_RICH_LOGGING",
      "advancedGroup": "Logging"
    }
  ],
  "guards": [
    {
      "when": { "deployment": ["server"], "auth": ["oidc", "both"] },
      "level": "warning",
      "message": "OIDC needs BASE_URL set and (on Linux/Docker) OIDC_JWT_SIGNING_KEY — the default key is ephemeral and invalidates tokens on restart."
    }
  ]
}
