# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

LOGODEV_MCP_BASE_URL=https://mcp.example.com
LOGODEV_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
LOGODEV_MCP_OIDC_CLIENT_ID=mcp-client
LOGODEV_MCP_OIDC_CLIENT_SECRET=your-client-secret
LOGODEV_MCP_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
LOGODEV_MCP_READ_ONLY=false
